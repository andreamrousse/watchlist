# Drizzle — use migrations only (`pnpm db:migrate`), not schema push.
# Replace with your DB credentials!
DATABASE_URL="postgres://user:password@host:port/db-name"

# Better Auth — must match where you load the site (scheme + host + port), e.g. http://localhost:5173
ORIGIN=""

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""

# Optional password-reset email via Resend (https://resend.com). If either is missing, reset links are
# only printed in the server terminal—nothing is mailed.
RESEND_API_KEY=""
MAIL_FROM=""